# ── DESARROLLO ──────────────────────────────────────────────────────────────
# URL del backend Ktor en la Raspberry Pi expuesto via ngrok.
# Copia este archivo como .env y pon la URL actual de ngrok.
# Solo se usa en "npm run dev"; en produccion no hace falta.
VITE_BACKEND_URL=https://tu-subdominio.ngrok-free.app

# ── PRODUCCION (opcional) ────────────────────────────────────────────────────
# Si el React NO es servido por Ktor (p.ej. nginx independiente),
# pon aqui la URL base del API (sin barra final).
# Si Ktor sirve el React, deja esto comentado.
# VITE_API_BASE_URL=https://tu-dominio.com
